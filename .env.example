# ── Option A: OpenAI directly ────────────────────────────────────────────────
# Leave blank to run in mock/simulation mode (no API key needed)
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# ── Option B: OpenRouter ──────────────────────────────────────────────────────
# Get a key at https://openrouter.ai/keys
# OPENAI_API_KEY=sk-or-v1-...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=openai/gpt-4o-mini          # or any model slug from openrouter.ai/models
# OPENAI_MODEL=meta-llama/llama-3.3-70b-instruct:free   # free tier, no credits needed

# Agent Settings
HITL_CONFIDENCE_THRESHOLD=0.7   # Actions below this confidence require human approval

# Storage
DB_PATH=autocs.db

# App
DEBUG=false
LOG_LEVEL=INFO
